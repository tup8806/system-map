[Unit]
Description=OpenClaw Gateway (v2026.3.2)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/bin/node /home/tup/.npm-global/lib/node_modules/openclaw/dist/index.js gateway --port 18789
Restart=always
RestartSec=5
KillMode=process
Environment=HOME=/home/tup
Environment=TMPDIR=/tmp
Environment=PATH=/home/tup/.local/bin:/home/tup/.npm-global/bin:/home/tup/bin:/home/tup/.volta/bin:/home/tup/.asdf/shims:/home/tup/.bun/bin:/home/tup/.nvm/current/bin:/home/tup/.fnm/current/bin:/home/tup/.local/share/pnpm:/usr/local/bin:/usr/bin:/bin
Environment=OPENCLAW_GATEWAY_PORT=18789
Environment=OPENCLAW_GATEWAY_TOKEN=cfefb003e4a054030da2e8f59f9a031e8d69b79f19f84f34
Environment=OPENCLAW_SYSTEMD_UNIT=openclaw-gateway.service
Environment=OPENCLAW_SERVICE_MARKER=openclaw
Environment=OPENCLAW_SERVICE_KIND=gateway
Environment=OPENCLAW_SERVICE_VERSION=2026.3.2

[Install]
WantedBy=default.target
