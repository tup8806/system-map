# Generic junk
*.log
*.tmp
.cache/
node_modules/
__pycache__/

# Environment / secrets
.env
.env.*
*.key
*.pem
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Raw scratch outputs
outputs/*.raw

# Sensitive exported configs
outputs/configs/network/NetworkManager/system-connections/
outputs/configs/system/etc-apt/auth.conf.d/
outputs/configs/ssh/etc-ssh/ssh_host_*_key
outputs/configs/ssh/etc-ssh/ssh_host_*_key.pub
outputs/configs/services/user-systemd/
outputs/configs/user-config/home-config/dconf/
outputs/configs/user-config/home-config/qBittorrent/
outputs/configs/user-config/home-config/pulse/
outputs/configs/user-config/home-config/systemd/

# Token-bearing OpenClaw user service files
outputs/configs/user-config/home-config/systemd/user/openclaw-gateway.service
outputs/configs/user-config/home-config/systemd/user/default.target.wants/openclaw-gateway.service
